{
  "name": "@tt23xrstudio/senri_ffi",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.0.0",
  "description": "Unified FFI library for [KossJS Runtime](github.com/KossJS), Node.js Runtime, and Bun Runtime",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "TT23XR Studio",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc"
  },
  "keywords": [
    "ffi",
    "senri",
    "kossjs",
    "bun",
    "node",
    "native",
    "c",
    "dlopen",
    "typescript"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "koffi": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "koffi": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
